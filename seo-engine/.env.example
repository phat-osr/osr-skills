# ============================================================
# OSR SEO engine — environment variables
# Copy this file to .env and fill in values. .env is gitignored — never commit it.
# Only the two "Required" vars are needed to start; the rest enable optional features.
# ============================================================

# --- Required ---
# Airtable personal access token (config.py reads from env, no hardcoded fallback)
AIRTABLE_PAT=your_airtable_personal_access_token
# Unsplash API access key (cover + supplementary images)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# --- Optional: keyword discovery (Step 0) ---
# DataForSEO login + password — needed only to run dfs_discover.py for new keyword batches
# DFS_LOGIN=your_dataforseo_login
# DFS_PASSWORD=your_dataforseo_password

# --- Optional: infographic hosting on Cloudflare R2 ---
# Written automatically by setup_r2.py; needed only when generating + hosting infographics
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# --- Optional: image fallback ---
# Google Custom Search — used only if Unsplash returns no good match
# GOOGLE_CSE_ID=your_google_cse_id
# GOOGLE_CSE_KEY=your_google_cse_api_key

# --- Optional: extras referenced by config_kw.py (not used by the core flow) ---
# UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here
# ANTHROPIC_API_KEY=
# FIRECRAWL_API_KEY=
# REDDIT_USER_AGENT=OSR-keyword-research/0.1
